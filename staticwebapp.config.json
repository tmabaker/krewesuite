{
  "routes": [
    {
      "route": "/kreweconnect",
      "redirect": "/kreweconnect/",
      "statusCode": 301
    },
    {
      "route": "/krewereview",
      "redirect": "/krewereview/",
      "statusCode": 301
    },
    {
      "route": "/app/kreweconnect",
      "redirect": "/app/kreweconnect/",
      "statusCode": 301
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/app/kreweconnect/assets/*",
      "/kreweconnect/*",
      "/krewereview/*",
      "/css/*",
      "/js/*",
      "*.css",
      "*.js",
      "*.png",
      "*.jpg",
      "*.svg",
      "*.ico",
      "*.woff2",
      "*.woff",
      "*.ttf",
      "*.map"
    ]
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "X-XSS-Protection": "1; mode=block",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".woff2": "font/woff2"
  }
}
