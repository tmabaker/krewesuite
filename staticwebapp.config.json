{
  "routes": [
    {
      "route": "/kreweconnect",
      "redirect": "/kreweconnect/",
      "statusCode": 301
    },
    {
      "route": "/krewereview",
      "redirect": "/krewereview/",
      "statusCode": 301
    },
    {
      "route": "/krewecatch",
      "redirect": "/krewecatch/",
      "statusCode": 301
    },
    {
      "route": "/krewegovernance",
      "redirect": "/krewegovernance/",
      "statusCode": 301
    },
    {
      "route": "/app/kreweconnect",
      "redirect": "/app/kreweconnect/",
      "statusCode": 301
    },
    {
      "route": "/app",
      "redirect": "/app/",
      "statusCode": 301
    }
  ],
  "navigationFallback": {
    "rewrite": "/app/kreweconnect/index.html",
    "exclude": [
      "*.{css,js,png,jpg,svg,ico,woff2,woff,ttf,map,json}",
      "/app/kreweconnect/assets/*",
      "/kreweconnect/*",
      "/krewereview/*",
      "/krewecatch/*",
      "/krewegovernance/*",
      "/css/*",
      "/js/*"
    ]
  },
  "globalHeaders": {
    "Content-Security-Policy": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.microsoft.com; font-src 'self' data:; connect-src 'self' https://login.microsoftonline.com https://graph.microsoft.com https://krewe-governance-api.azurewebsites.net; frame-ancestors 'none'; base-uri 'self'",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains",
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "X-XSS-Protection": "0",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Access-Control-Allow-Origin": "https://techtools.noitgroup.com",
    "Access-Control-Allow-Methods": "GET,POST,PATCH,OPTIONS",
    "Access-Control-Allow-Headers": "Authorization,X-KreweConnect-Auth,Content-Type",
    "Access-Control-Max-Age": "3600"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".woff2": "font/woff2"
  }
}
