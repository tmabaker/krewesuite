{
  "routes": [
    {
      "route": "/kreweconnect",
      "redirect": "/kreweconnect/",
      "statusCode": 301
    },
    {
      "route": "/krewereview",
      "redirect": "/krewereview/",
      "statusCode": 301
    },
    {
      "route": "/app/kreweconnect",
      "redirect": "/app/kreweconnect/",
      "statusCode": 301
    },
    {
      "route": "/app",
      "redirect": "/app/",
      "statusCode": 301
    }
  ],
  "navigationFallback": {
    "rewrite": "/app/kreweconnect/index.html",
    "exclude": [
      "*.{css,js,png,jpg,svg,ico,woff2,woff,ttf,map,json}",
      "/app/kreweconnect/assets/*",
      "/kreweconnect/*",
      "/krewereview/*",
      "/css/*",
      "/js/*"
    ]
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "X-XSS-Protection": "1; mode=block",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".woff2": "font/woff2"
  }
}
